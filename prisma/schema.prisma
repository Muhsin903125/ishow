generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("CUSTOMER")
  createdAt DateTime @default(now())

  assessment   Assessment?
  plans        Plan[]        @relation("CustomerPlans")
  trainerPlans Plan[]        @relation("TrainerPlans")
  sessions     Session[]     @relation("CustomerSessions")
  trainerSessions Session[]  @relation("TrainerSessions")
  programs     Program[]     @relation("CustomerPrograms")
  trainerPrograms Program[]  @relation("TrainerPrograms")
  payments     Payment[]
}

model Assessment {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  age                Int
  weight             Float
  height             Float
  fitnessGoal        String
  currentFitnessLevel String
  healthConditions   String?
  availability       String
  experience         String
  status             String   @default("PENDING")
  createdAt          DateTime @default(now())
}

model Plan {
  id               String   @id @default(cuid())
  customerId       String
  customer         User     @relation("CustomerPlans", fields: [customerId], references: [id])
  trainerId        String
  trainer          User     @relation("TrainerPlans", fields: [trainerId], references: [id])
  name             String
  description      String?
  goals            String?
  monthlyRate      Float
  paymentFrequency String   @default("MONTHLY")
  startDate        DateTime
  status           String   @default("ACTIVE")
  payments         Payment[]
  createdAt        DateTime @default(now())
}

model Session {
  id            String   @id @default(cuid())
  customerId    String
  customer      User     @relation("CustomerSessions", fields: [customerId], references: [id])
  trainerId     String
  trainer       User     @relation("TrainerSessions", fields: [trainerId], references: [id])
  title         String
  scheduledDate DateTime
  scheduledTime String
  duration      Int      @default(60)
  status        String   @default("SCHEDULED")
  notes         String?
  createdAt     DateTime @default(now())
}

model Program {
  id          String     @id @default(cuid())
  customerId  String
  customer    User       @relation("CustomerPrograms", fields: [customerId], references: [id])
  trainerId   String
  trainer     User       @relation("TrainerPrograms", fields: [trainerId], references: [id])
  weekNumber  Int
  title       String
  description String?
  activities  Activity[]
  createdAt   DateTime   @default(now())
}

model Activity {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  day       String
  name      String
  sets      Int?
  reps      Int?
  duration  Int?
  notes     String?
}

model Payment {
  id            String   @id @default(cuid())
  customerId    String
  customer      User     @relation(fields: [customerId], references: [id])
  planId        String
  plan          Plan     @relation(fields: [planId], references: [id])
  amount        Float
  paymentDate   DateTime?
  dueDate       DateTime
  status        String   @default("PENDING")
  paymentMethod String?
  createdAt     DateTime @default(now())
}
